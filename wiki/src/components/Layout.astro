---
import '../styles/theme.css';
import { wt, WIKI_LANG } from '../lib/i18n';

interface Props {
  title: string;
}
const { title } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
function active(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---
<html lang={WIKI_LANG}>
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/custom40k-logo.png" />
  </head>
  <body>
    <header class="site-nav">
      <a href="/" class={active('/') ? 'nav-active' : ''}>{wt('navHome')}</a>
      <a href="/factions" class={active('/factions') ? 'nav-active' : ''}>{wt('navFactions')}</a>
      <a href="/missions" class={active('/missions') ? 'nav-active' : ''}>{wt('navMissions')}</a>
      <a href="/rules" class={active('/rules') ? 'nav-active' : ''}>{wt('navRules')}</a>
      <a href="/glossary" class={active('/glossary') ? 'nav-active' : ''}>{wt('navGlossary')}</a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="wiki-footer">
      <a href="https://discord.com/invite/wnGAB3TYAY" target="_blank" rel="noopener" class="discord-footer-link">
        <svg class="discord-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 0 0-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 0 0-5.487 0 12.36 12.36 0 0 0-.617-1.23A.077.077 0 0 0 8.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 0 0-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 0 0 .031.055 20.03 20.03 0 0 0 5.993 2.98.078.078 0 0 0 .084-.026c.462-.62.874-1.275 1.226-1.963.021-.04.001-.088-.041-.104a13.201 13.201 0 0 1-1.872-.878.075.075 0 0 1-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 0 1 .078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 0 1 .079.009c.12.098.245.195.372.288a.075.075 0 0 1-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 0 0-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 0 0 .084.028 19.963 19.963 0 0 0 6.002-2.981.076.076 0 0 0 .032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 0 0-.031-.028zM8.02 15.278c-1.182 0-2.157-1.069-2.157-2.38 0-1.312.956-2.38 2.157-2.38 1.21 0 2.176 1.077 2.157 2.38 0 1.312-.956 2.38-2.157 2.38zm7.975 0c-1.183 0-2.157-1.069-2.157-2.38 0-1.312.955-2.38 2.157-2.38 1.21 0 2.176 1.077 2.157 2.38 0 1.312-.946 2.38-2.157 2.38z"/>
        </svg>
        <span>{wt('footerDiscord')}</span>
      </a>
    </footer>
  </body>
  <script is:inline>
    (function () {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.08 });
      document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
    })();
  </script>
</html>

<style>
  .site-nav {
    display: flex; justify-content: center; gap: 0.2rem;
    max-width: 1000px; margin: 0 auto; padding: 0.7rem 2rem 0;
    font-family: var(--font-ui, sans-serif); text-transform: uppercase; letter-spacing: 0.06em;
    font-size: 0.68rem;
    position: relative; z-index: 100;
  }
  .site-nav a {
    color: var(--c40k-ink, #2a2420);
    text-decoration: none;
    opacity: 0.65;
    padding: 0.35rem 0.7rem;
    border-bottom: 2px solid transparent;
    transition: opacity 0.15s, color 0.15s, border-color 0.15s;
    cursor: pointer;
  }
  .site-nav a:hover {
    opacity: 1;
    color: var(--c40k-red, #a21217);
    text-decoration: none;
    border-bottom-color: rgba(162,18,23,0.35);
  }
  .site-nav a.nav-active {
    opacity: 1;
    color: var(--c40k-red, #a21217);
    border-bottom-color: var(--c40k-red, #a21217);
    font-weight: 700;
  }

  /* ── Discord footer ──────────────────────────────────────── */
  .wiki-footer {
    max-width: 1000px; margin: 3rem auto 0; padding: 1.2rem 2rem;
    border-top: 1px solid rgba(57,73,80,0.2);
    display: flex; justify-content: center;
  }
  .discord-footer-link {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-family: var(--font-ui, sans-serif); font-size: 0.68rem;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--c40k-ink, #2a2420); opacity: 0.55;
    text-decoration: none;
    padding: 0.4rem 0.9rem;
    border: 1px solid rgba(88,101,242,0.25);
    border-radius: 4px;
    background: rgba(88,101,242,0.04);
    transition: opacity 0.15s, background 0.15s, border-color 0.15s, color 0.15s;
  }
  .discord-footer-link:hover {
    opacity: 1; color: #5865F2;
    background: rgba(88,101,242,0.10);
    border-color: rgba(88,101,242,0.5);
    text-decoration: none;
  }
  .discord-icon {
    width: 16px; height: 16px; fill: currentColor; flex-shrink: 0;
  }
</style>

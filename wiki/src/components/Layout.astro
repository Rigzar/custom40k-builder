---
import '../styles/theme.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
function active(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/custom40k-logo.png" />
  </head>
  <body>
    <header class="site-nav">
      <a href="/" class={active('/') ? 'nav-active' : ''}>Home</a>
      <a href="/factions" class={active('/factions') ? 'nav-active' : ''}>Factions</a>
      <a href="/missions" class={active('/missions') ? 'nav-active' : ''}>Missions</a>
      <a href="/rules" class={active('/rules') ? 'nav-active' : ''}>Core Rules</a>
      <a href="/glossary" class={active('/glossary') ? 'nav-active' : ''}>Glossary</a>
    </header>
    <main>
      <slot />
    </main>
  </body>
  <script is:inline>
    (function () {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.08 });
      document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
    })();
  </script>
</html>

<style>
  .site-nav {
    display: flex; justify-content: center; gap: 0.2rem;
    max-width: 1000px; margin: 0 auto; padding: 0.7rem 2rem 0;
    font-family: var(--font-ui, sans-serif); text-transform: uppercase; letter-spacing: 0.06em;
    font-size: 0.68rem;
    position: relative; z-index: 100;
  }
  .site-nav a {
    color: var(--c40k-ink, #2a2420);
    text-decoration: none;
    opacity: 0.65;
    padding: 0.35rem 0.7rem;
    border-bottom: 2px solid transparent;
    transition: opacity 0.15s, color 0.15s, border-color 0.15s;
    cursor: pointer;
  }
  .site-nav a:hover {
    opacity: 1;
    color: var(--c40k-red, #a21217);
    text-decoration: none;
    border-bottom-color: rgba(162,18,23,0.35);
  }
  .site-nav a.nav-active {
    opacity: 1;
    color: var(--c40k-red, #a21217);
    border-bottom-color: var(--c40k-red, #a21217);
    font-weight: 700;
  }
</style>

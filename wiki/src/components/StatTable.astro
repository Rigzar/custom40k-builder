---
import type { Model } from '../../../src/types/data';

interface Props {
  models: Model[];
  title?: string;
}
const { models, title } = Astro.props;

const cols = ['M', 'WS', 'BS', 'S', 'T', 'W', 'I', 'A', 'LD', 'SV', 'FRONT', 'SIDE', 'REAR', 'HP'] as const;
const usedCols = cols.filter(c => models.some(m => m.stats[c] !== undefined));
---
{title && <h3>{title}</h3>}
<table class="stat-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Pts</th>
      <th>Min</th>
      <th>Max</th>
      {usedCols.map(c => <th>{c}</th>)}
    </tr>
  </thead>
  <tbody>
    {models.map(m => (
      <tr>
        <td>{m.name}</td>
        <td>{m.points}</td>
        <td>{m.min}</td>
        <td>{m.max}</td>
        {usedCols.map(c => <td>{m.stats[c] ?? '-'}</td>)}
      </tr>
    ))}
  </tbody>
</table>

<style>
  .stat-table th, .stat-table td { text-align: center; }
  .stat-table th:first-child, .stat-table td:first-child { text-align: left; }
</style>

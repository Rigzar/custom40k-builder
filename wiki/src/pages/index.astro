---
import Layout from '../components/Layout.astro';
import FactionHeader from '../components/FactionHeader.astro';
import { PILOT_FACTIONS } from '../lib/factions';
---
<Layout title="Custom40k Wiki">
  <h1>Custom40k Wiki</h1>
  <p>Faction codices — units, weapons, abilities and points, generated from the canonical data.</p>
  <div class="faction-grid">
    {PILOT_FACTIONS.map(f => (
      <FactionHeader label={f.label} symbol={f.symbol} href={`/factions/${f.key}`} />
    ))}
  </div>
</Layout>

<style>
  .faction-grid { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-top: 1.5rem; }
</style>

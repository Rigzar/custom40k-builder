---
import Layout from '../../../components/Layout.astro';
import { ALL_FACTIONS } from '../../../lib/factions';
import { getFactionExtras } from '../../../lib/factionExtras';
import { getFactionDescription, getFactionVersion } from '../../../lib/factionMeta';
import { ARMY_RULES } from '../../../lib/armyRules';

export async function getStaticPaths() {
  return ALL_FACTIONS.map(f => ({ params: { faction: f.key } }));
}

const { faction: factionKey } = Astro.params;
const config = ALL_FACTIONS.find(f => f.key === factionKey)!;
const { armoryGeneral, armoryFaction, archetypes, legacies, traits, disciplines, prayers, pacts, animosity, canticles } = await getFactionExtras(factionKey!);

const hasArmory = armoryGeneral.weapons.length > 0 || armoryGeneral.equipment.length > 0
  || (armoryGeneral.daemon_weapons && armoryGeneral.daemon_weapons.length > 0)
  || Object.keys(armoryFaction).length > 0;
const hasCustomisation = archetypes.length > 0 || legacies.length > 0 || traits.length > 0;
const hasPsychic = Object.keys(disciplines).length > 0;
const hasPrayers = (prayers && prayers.length > 0) || (pacts && pacts.length > 0);

const description = getFactionDescription(factionKey!);
const codexVersion = getFactionVersion(factionKey!);
const hasWarbands = factionKey === 'inquisition';

const PRAYER_LABELS: Record<string, string> = {
  space_marines: 'Litanies', adeptus_sororitas: 'Litanies', grey_knights: 'Litanies',
  imperial_guard: 'Litanies', inquisition: 'Litanies', tau_empire: 'Mantras',
};
const prayerNavLabel = (pacts && pacts.length > 0)
  ? 'Prayers & Pacts'
  : (PRAYER_LABELS[factionKey!] ?? 'Prayers');

const MARK_ICONS: Record<string, string> = {
  'Khorne':   '/legion-symbols/khorne-god.svg',
  'Nurgle':   '/legion-symbols/nurgle-god.svg',
  'Slaanesh': '/legion-symbols/slaanesh-god.svg',
  'Tzeentch': '/legion-symbols/tzeentch-god.svg',
};

const MARK_COLORS: Record<string, string> = {
  'Khorne':   '#8b1c1c',
  'Nurgle':   '#4a6b2a',
  'Slaanesh': '#7b4a8b',
  'Tzeentch': '#1e5a8b',
};

// Compute rival pairs: marks that CANNOT share a squad
const rivalPairs: [string, string][] = (() => {
  if (!animosity) return [];
  const keys = Object.keys(animosity);
  const seen = new Set<string>();
  const pairs: [string, string][] = [];
  keys.forEach(keyA => {
    const compatA = new Set(animosity![keyA] as string[]);
    keys.forEach(keyB => {
      if (keyA === keyB) return;
      // normalize "Undivided / Without" → "Undivided" for lookup
      const bNorm = keyB.replace(/ \/ Without$/, '').trim();
      if (!compatA.has(keyB) && !compatA.has(bNorm)) {
        const pairKey = [keyA, keyB].sort().join('||');
        if (!seen.has(pairKey)) { seen.add(pairKey); pairs.push([keyA, keyB]); }
      }
    });
  });
  return pairs;
})();

const baseCanticles = canticles?.filter(c => c.type === 'base') ?? [];
const legacyCanticles = canticles?.filter(c => c.type === 'legacy') ?? [];

const armyRules = ARMY_RULES[factionKey!] ?? [];
const TAG_LABELS: Record<string, string> = {
  signature: 'Signature',
  universal: 'Army-wide',
  ally: 'Alliance',
  deployment: 'Deployment',
  weapon: 'Weapon Rule',
};
const TAG_COLORS: Record<string, string> = {
  signature: '#7a1c1c',
  universal: '#2a4a6a',
  ally: '#2a5a3a',
  deployment: '#5a3a6a',
  weapon: '#5a4a1a',
};
---
<Layout title={`${config.label} — Custom40k Wiki`}>
  <p class="crumbs"><a href="/factions">&larr; All factions</a></p>

  <div class="hub">
    <img src={`/faction-symbols/${config.symbol}`} alt={config.label} class="hub-symbol" width="140" height="140" />
    <h1 class="hub-title">{config.label}</h1>
    {codexVersion && <p class="hub-version">Codex v{codexVersion}</p>}

    {/* ── Description card with side servo skull ── */}
    <div class="desc-outer reveal">
      <div class="desc-skull-col">
        <img src="/servo-skull.png" class="desc-skull" alt="" />
        <div class="desc-chain"></div>
      </div>
      <div class="desc-card">
        <p class="desc-text">{description}</p>
      </div>
    </div>

    {/* ── Army Rules ── */}
    {armyRules.length > 0 && (
      <section class="army-rules-section reveal">
        <div class="rules-section-header">
          <svg class="rules-section-icon" width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
            <polygon points="9,1 11,6.5 17,6.5 12.5,10 14.5,16 9,12.5 3.5,16 5.5,10 1,6.5 7,6.5"/>
          </svg>
          <h2 class="rules-section-title">Army Rules</h2>
          <div class="rules-section-line"/>
        </div>
        <div class="rules-list">
          {armyRules.map(rule => (
            <div class={`rule-card rule-card--${rule.tag ?? 'universal'}`}>
              <div class="rule-card-header">
                <span class="rule-name">{rule.name}</span>
                {rule.tag && (
                  <span class="rule-tag" style={`--tag-color: ${TAG_COLORS[rule.tag] ?? '#444'}`}>
                    {TAG_LABELS[rule.tag]}
                  </span>
                )}
              </div>
              <p class="rule-desc">{rule.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ── Chaos Marks Animosity (CSM + CD) ── */}
    {animosity && rivalPairs.length > 0 && (
      <section class="army-rules reveal">
        <h2 class="rules-heading">Chaos Marks Animosity</h2>
        <p class="rules-note">Units bearing rival Marks <strong>cannot share a squad</strong>. All other Mark combinations — and any unit with the Undivided / Without Mark — are freely compatible.</p>
        <div class="rival-grid">
          {rivalPairs.map(([a, b]) => (
            <div class="rival-row">
              <div class="rival-mark" style={`--mark-color: ${MARK_COLORS[a] ?? '#6b1a1a'}`}>
                {MARK_ICONS[a]
                  ? <img src={MARK_ICONS[a]} alt={a} class="rival-icon" />
                  : <span class="rival-icon-fallback">⚔</span>}
                <span class="rival-name">{a}</span>
              </div>
              <div class="rival-vs" aria-label="cannot join with">✕</div>
              <div class="rival-mark" style={`--mark-color: ${MARK_COLORS[b] ?? '#6b1a1a'}`}>
                {MARK_ICONS[b]
                  ? <img src={MARK_ICONS[b]} alt={b} class="rival-icon" />
                  : <span class="rival-icon-fallback">⚔</span>}
                <span class="rival-name">{b}</span>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ── Canticles of the Omnissiah (AdMech) ── */}
    {canticles && canticles.length > 0 && (
      <section class="army-rules reveal">
        <div class="skull-heading">
          <img src="/servo-skull.png" class="skull-heading-img" alt="" />
          <h2 class="rules-heading">Canticles of the Omnissiah</h2>
        </div>
        <p class="rules-note">At the start of each battle round, roll a d6 for each AdMech unit. On a 4+ the unit may use one base canticle. Legacy canticles require the matching Legacy.</p>

        {baseCanticles.length > 0 && (
          <>
            <h3 class="sub-heading">Base Canticles</h3>
            <table class="canticle-table">
              <thead><tr><th>Canticle</th><th>Effect</th></tr></thead>
              <tbody>
                {baseCanticles.map(c => (
                  <tr>
                    <td class="canticle-name">{c.name}</td>
                    <td>{c.effect}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        )}

        {legacyCanticles.length > 0 && (
          <>
            <h3 class="sub-heading">Legacy Canticles</h3>
            <table class="canticle-table">
              <thead><tr><th>Canticle</th><th>Granted by</th><th>Effect</th></tr></thead>
              <tbody>
                {legacyCanticles.map(c => (
                  <tr>
                    <td class="canticle-name">{c.name}</td>
                    <td class="legacy-name">{c.grantedByLegacy}</td>
                    <td>{c.effect}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        )}
      </section>
    )}

    <nav class="hub-nav reveal">
      <a href={`/factions/${factionKey}/units`} class="nav-btn primary">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><rect x="0" y="1" width="14" height="2"/><rect x="0" y="6" width="14" height="2"/><rect x="0" y="11" width="14" height="2"/></svg>
        Units
      </a>
      {hasArmory && (
        <a href={`/factions/${factionKey}/armory`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M2 12 L7 2 L12 12 L9 10 L7 13 L5 10 Z"/></svg>
          Armory
        </a>
      )}
      {hasWarbands && (
        <a href={`/factions/${factionKey}/warbands`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><circle cx="5" cy="4" r="2"/><circle cx="9" cy="4" r="2"/><path d="M1 12 C1 8 4 7 5 7 C6 7 8 7 9 7 C10 7 13 8 13 12"/></svg>
          Warbands
        </a>
      )}
      {hasCustomisation && (
        <a href={`/factions/${factionKey}/archetypes`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><circle cx="7" cy="7" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="7" cy="7" r="2"/></svg>
          Army Customisation
        </a>
      )}
      {hasPsychic && (
        <a href={`/factions/${factionKey}/psychic`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1 L8.5 5.5 L13 5.5 L9.5 8.5 L11 13 L7 10 L3 13 L4.5 8.5 L1 5.5 L5.5 5.5 Z"/></svg>
          Psychic Powers
        </a>
      )}
      {hasPrayers && (
        <a href={`/factions/${factionKey}/prayers`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 0 C7 0 4 3 4 6 C4 7.66 5.34 9 7 9 C8.66 9 10 7.66 10 6 C10 3 7 0 7 0 Z M5 11 L9 11 L8.5 14 L5.5 14 Z"/></svg>
          {prayerNavLabel}
        </a>
      )}
    </nav>
  </div>
</Layout>

<style>
  .hub { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 1.5rem 0 1rem; }

  .hub-symbol {
    object-fit: contain; margin-bottom: 0.8rem;
    animation: symbol-emerge 1.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hub-title { margin: 0 0 0.4rem; animation: title-reveal 0.9s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .hub-version {
    margin: 0 0 0.6rem; font-family: 'Cinzel', serif; font-size: 0.7rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: #b8945a; opacity: 0.85;
    animation: title-reveal 0.9s 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── Description card with side servo skull ── */
  .desc-outer {
    display: flex;
    align-items: stretch;
    max-width: 42rem;
    width: 100%;
    margin: 0 0 1.8rem;
    animation: fade-up 0.8s 0.6s both;
  }
  .desc-skull-col {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.5rem;
    margin-right: -1px;
    z-index: 2;
  }
  .desc-skull {
    width: 72px;
    height: 72px;
    object-fit: contain;
    filter: drop-shadow(0 2px 14px rgba(180,83,9,0.5));
    flex-shrink: 0;
  }
  .desc-chain {
    width: 2px;
    flex: 1;
    min-height: 12px;
    background: linear-gradient(to bottom, rgba(162,130,60,0.55), rgba(162,130,60,0.05));
    margin-top: 2px;
  }
  .desc-card {
    flex: 1;
    border: 1px solid rgba(162,18,23,0.28);
    border-left: 3px solid rgba(162,18,23,0.55);
    padding: 1rem 1.2rem;
    background: rgba(255,252,240,0.72);
    box-shadow: 2px 3px 10px rgba(0,0,0,0.10);
    text-align: left;
  }
  .desc-text {
    font-size: 0.85rem;
    line-height: 1.65;
    margin: 0;
    color: var(--c40k-ink);
    font-style: italic;
  }

  /* ── Army Rules (main section) ── */
  .army-rules-section {
    width: 100%;
    max-width: 42rem;
    margin-bottom: 2rem;
    text-align: left;
  }
  .rules-section-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .rules-section-icon {
    color: var(--c40k-red, #a21217);
    flex-shrink: 0;
    opacity: 0.85;
  }
  .rules-section-title {
    font-family: var(--font-ui, sans-serif);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c40k-red, #a21217);
    margin: 0;
    white-space: nowrap;
    border-bottom: none;
    padding-bottom: 0;
    animation: none;
  }
  .rules-section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(162,18,23,0.35) 0%, rgba(162,18,23,0.06) 100%);
  }
  .rules-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .rule-card {
    border-left: 4px solid var(--c40k-red, #a21217);
    border-top: 1px solid rgba(162,18,23,0.18);
    border-right: 1px solid rgba(162,18,23,0.10);
    border-bottom: 1px solid rgba(162,18,23,0.10);
    background: linear-gradient(135deg, rgba(255,252,240,0.82) 0%, rgba(255,252,240,0.58) 100%);
    padding: 0.75rem 1rem;
    position: relative;
    transition: box-shadow 0.15s, transform 0.12s;
  }
  .rule-card:hover {
    box-shadow: 2px 5px 18px rgba(162,18,23,0.13);
    transform: translateX(2px);
  }
  .rule-card--signature {
    border-left-color: #8b1c1c;
    border-left-width: 5px;
    background: linear-gradient(135deg, rgba(139,28,28,0.07) 0%, rgba(255,252,240,0.78) 40%, rgba(255,252,240,0.58) 100%);
  }
  .rule-card--universal  {
    border-left-color: #1e4e7a;
    background: linear-gradient(135deg, rgba(30,78,122,0.06) 0%, rgba(255,252,240,0.78) 40%, rgba(255,252,240,0.58) 100%);
  }
  .rule-card--ally       {
    border-left-color: #1e5a30;
    background: linear-gradient(135deg, rgba(30,90,48,0.06) 0%, rgba(255,252,240,0.78) 40%, rgba(255,252,240,0.58) 100%);
  }
  .rule-card--deployment {
    border-left-color: #5a2e7a;
    background: linear-gradient(135deg, rgba(90,46,122,0.06) 0%, rgba(255,252,240,0.78) 40%, rgba(255,252,240,0.58) 100%);
  }
  .rule-card--weapon     {
    border-left-color: #6b4a12;
    background: linear-gradient(135deg, rgba(107,74,18,0.06) 0%, rgba(255,252,240,0.78) 40%, rgba(255,252,240,0.58) 100%);
  }
  .rule-card-header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.3rem;
  }
  .rule-name {
    font-family: var(--font-ui, sans-serif);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c40k-ink);
    line-height: 1.2;
  }
  .rule-tag {
    display: inline-block;
    font-family: var(--font-ui, sans-serif);
    font-size: 0.60rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: var(--tag-color, #555);
    padding: 0.1em 0.5em 0.15em;
    border-radius: 2px;
    opacity: 0.88;
    flex-shrink: 0;
  }
  .rule-desc {
    font-size: 0.80rem;
    line-height: 1.6;
    color: var(--c40k-ink);
    margin: 0;
    opacity: 0.85;
  }

  /* ── Army rules sections (animosity/canticles) ── */
  .army-rules { width: 100%; max-width: 42rem; margin-bottom: 1.6rem; text-align: left; }
  .rules-heading { font-size: 1rem; margin: 0 0 0.4rem; border-bottom: none; padding-bottom: 0; animation: none; }
  .sub-heading { font-size: 0.82rem; margin: 0.9rem 0 0.35rem; border-bottom: none; animation: none; color: var(--c40k-steel, #394950); }
  .rules-note { font-size: 0.78rem; opacity: 0.7; margin: 0 0 0.8rem; font-style: italic; }

  /* ── Animosity rival pairs ── */
  .rival-grid {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .rival-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    background: rgba(255,252,240,0.60);
    border: 1px solid rgba(162,18,23,0.20);
    padding: 0.65rem 1rem;
  }
  .rival-mark {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }
  .rival-icon {
    width: 36px; height: 36px;
    object-fit: contain;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 6px rgba(0,0,0,0.3));
  }
  .rival-icon-fallback { font-size: 1.5rem; flex-shrink: 0; }
  .rival-name {
    font-family: var(--font-ui, sans-serif);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--mark-color, var(--c40k-ink));
    white-space: nowrap;
  }
  .rival-vs {
    font-size: 1.1rem;
    font-weight: 900;
    color: rgba(162,18,23,0.75);
    flex-shrink: 0;
    width: 1.6rem;
    text-align: center;
  }

  /* ── Canticles table ── */
  .canticle-table { font-size: 0.82rem; margin: 0 0 0.5rem; }
  .canticle-table th { text-align: left; }
  .canticle-name { font-family: var(--font-ui, sans-serif); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.02em; white-space: nowrap; }
  .legacy-name { font-size: 0.78rem; opacity: 0.75; white-space: nowrap; }

  /* ── Skull heading (canticles) ── */
  .skull-heading { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem; }
  .skull-heading-img { width: 36px; height: 36px; object-fit: contain; filter: drop-shadow(0 1px 6px rgba(180,83,9,0.35)); }

  /* ── Nav ── */
  .hub-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; animation: fade-up 0.8s 0.9s both; }
  .nav-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-ui, sans-serif); text-transform: uppercase; letter-spacing: 0.04em;
    font-size: 0.75rem; padding: 0.55rem 1.2rem;
    border: 1px solid var(--c40k-red, #a21217); color: var(--c40k-red, #a21217);
    text-decoration: none; border-radius: 3px; transition: background 0.15s, color 0.15s;
  }
  .nav-btn:hover { background: var(--c40k-red, #a21217); color: #fff; }
  .nav-btn.primary { background: var(--c40k-red, #a21217); color: #fff; }
  .nav-btn.primary:hover { background: #8a0e12; }
</style>

---
import Layout from '../../../components/Layout.astro';
import { ALL_FACTIONS } from '../../../lib/factions';
import { getFactionExtras } from '../../../lib/factionExtras';
import { getFactionDescription } from '../../../lib/factionMeta';

export async function getStaticPaths() {
  return ALL_FACTIONS.map(f => ({ params: { faction: f.key } }));
}

const { faction: factionKey } = Astro.params;
const config = ALL_FACTIONS.find(f => f.key === factionKey)!;
const { armoryGeneral, armoryFaction, archetypes, legacies, traits, disciplines, prayers, pacts, animosity, canticles } = await getFactionExtras(factionKey!);

const hasArmory = armoryGeneral.weapons.length > 0 || armoryGeneral.equipment.length > 0
  || (armoryGeneral.daemon_weapons && armoryGeneral.daemon_weapons.length > 0)
  || Object.keys(armoryFaction).length > 0;
const hasCustomisation = archetypes.length > 0 || legacies.length > 0 || traits.length > 0;
const hasPsychic = Object.keys(disciplines).length > 0;
const hasPrayers = (prayers && prayers.length > 0) || (pacts && pacts.length > 0);

const description = getFactionDescription(factionKey!);

const MARK_ICONS: Record<string, string> = {
  'Khorne':  '/legion-symbols/khorne-god.svg',
  'Nurgle':  '/legion-symbols/nurgle-god.svg',
  'Slaanesh': '/legion-symbols/slaanesh-god.svg',
  'Tzeentch': '/legion-symbols/tzeentch-god.svg',
  // Undivided/Without has no dedicated icon — intentionally omitted (no broken img)
};

const baseCanticles = canticles?.filter(c => c.type === 'base') ?? [];
const legacyCanticles = canticles?.filter(c => c.type === 'legacy') ?? [];
---
<Layout title={`${config.label} — Custom40k Wiki`}>
  <p class="crumbs"><a href="/factions">&larr; All factions</a></p>

  <div class="hub">
    <img src={`/faction-symbols/${config.symbol}`} alt={config.label} class="hub-symbol" width="140" height="140" />
    <h1 class="hub-title">{config.label}</h1>
    <p class="hub-desc">{description}</p>

    {/* ── Chaos Marks Animosity (CSM + CD) ── */}
    {animosity && Object.keys(animosity).length > 0 && (
      <section class="army-rules reveal">
        <div class="skull-heading">
          <img src="/servo-skull.png" class="skull-heading-img" alt="" />
          <h2 class="rules-heading">Chaos Marks Animosity</h2>
        </div>
        <p class="rules-note">Units with different Marks may only join together if their Marks are mutually compatible.</p>
        <table class="animosity-table">
          <thead>
            <tr><th>Mark</th><th>Compatible with</th></tr>
          </thead>
          <tbody>
            {Object.entries(animosity).map(([mark, compatible]) => (
              <tr>
                <td class="mark-cell">
                  {MARK_ICONS[mark] && <img src={MARK_ICONS[mark]} alt="" width="16" height="16" class="mark-icon" />}
                  {mark}
                </td>
                <td class="compat-cell">
                  {compatible.map(c => (
                    <span class="mark-pill">
                      {MARK_ICONS[c] && <img src={MARK_ICONS[c]} alt="" width="13" height="13" class="mark-icon" />}
                      {c}
                    </span>
                  ))}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {/* ── Canticles of the Omnissiah (AdMech) ── */}
    {canticles && canticles.length > 0 && (
      <section class="army-rules reveal">
        <div class="skull-heading">
          <img src="/servo-skull.png" class="skull-heading-img" alt="" />
          <h2 class="rules-heading">Canticles of the Omnissiah</h2>
        </div>
        <p class="rules-note">At the start of each battle round, roll a d6 for each AdMech unit. On a 4+ the unit may use one base canticle. Legacy canticles require the matching Legacy.</p>

        {baseCanticles.length > 0 && (
          <>
            <h3 class="sub-heading">Base Canticles</h3>
            <table class="canticle-table">
              <thead><tr><th>Canticle</th><th>Effect</th></tr></thead>
              <tbody>
                {baseCanticles.map(c => (
                  <tr>
                    <td class="canticle-name">{c.name}</td>
                    <td>{c.effect}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        )}

        {legacyCanticles.length > 0 && (
          <>
            <h3 class="sub-heading">Legacy Canticles</h3>
            <table class="canticle-table">
              <thead><tr><th>Canticle</th><th>Granted by</th><th>Effect</th></tr></thead>
              <tbody>
                {legacyCanticles.map(c => (
                  <tr>
                    <td class="canticle-name">{c.name}</td>
                    <td class="legacy-name">{c.grantedByLegacy}</td>
                    <td>{c.effect}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        )}
      </section>
    )}

    <nav class="hub-nav reveal">
      <a href={`/factions/${factionKey}/units`} class="nav-btn primary">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><rect x="0" y="1" width="14" height="2"/><rect x="0" y="6" width="14" height="2"/><rect x="0" y="11" width="14" height="2"/></svg>
        Units
      </a>
      {hasArmory && (
        <a href={`/factions/${factionKey}/armory`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M2 12 L7 2 L12 12 L9 10 L7 13 L5 10 Z"/></svg>
          Armory
        </a>
      )}
      {hasCustomisation && (
        <a href={`/factions/${factionKey}/archetypes`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><circle cx="7" cy="7" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="7" cy="7" r="2"/></svg>
          Army Customisation
        </a>
      )}
      {hasPsychic && (
        <a href={`/factions/${factionKey}/psychic`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1 L8.5 5.5 L13 5.5 L9.5 8.5 L11 13 L7 10 L3 13 L4.5 8.5 L1 5.5 L5.5 5.5 Z"/></svg>
          Psychic Powers
        </a>
      )}
      {hasPrayers && (
        <a href={`/factions/${factionKey}/prayers`} class="nav-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 0 C7 0 4 3 4 6 C4 7.66 5.34 9 7 9 C8.66 9 10 7.66 10 6 C10 3 7 0 7 0 Z M5 11 L9 11 L8.5 14 L5.5 14 Z"/></svg>
          {(pacts && pacts.length > 0) ? 'Prayers & Pacts' : 'Prayers'}
        </a>
      )}
    </nav>
  </div>
</Layout>

<style>
  .hub { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 1.5rem 0 1rem; }

  .hub-symbol {
    object-fit: contain; margin-bottom: 0.8rem;
    animation: symbol-emerge 1.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hub-title { margin: 0; animation: title-reveal 0.9s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .hub-desc {
    max-width: 38rem; opacity: 0.85; font-size: 0.85rem; line-height: 1.5;
    margin: 0.6rem 0 1.6rem;
    animation: fade-up 0.8s 0.6s both;
  }

  /* Army rules sections */
  .army-rules { width: 100%; max-width: 40rem; margin-bottom: 1.6rem; text-align: left; }
  .rules-heading { font-size: 1rem; margin: 0; border-bottom: none; padding-bottom: 0; animation: none; }
  .sub-heading { font-size: 0.82rem; margin: 0.9rem 0 0.35rem; border-bottom: none; animation: none; color: var(--c40k-steel, #394950); }
  .rules-note { font-size: 0.78rem; opacity: 0.7; margin: 0 0 0.6rem; font-style: italic; }

  /* Animosity table */
  .animosity-table { font-size: 0.82rem; margin: 0; }
  .animosity-table th { text-align: left; }
  .mark-cell { display: flex; align-items: center; gap: 0.4rem; white-space: nowrap; font-family: var(--font-ui, sans-serif); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.03em; }
  .mark-icon { object-fit: contain; flex-shrink: 0; }
  .compat-cell { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; padding: 0.3rem 0.5rem; }
  .mark-pill { display: inline-flex; align-items: center; gap: 0.25rem; font-family: var(--font-ui, sans-serif); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.02em; padding: 0.15rem 0.45rem; border: 1px solid rgba(162,18,23,0.4); border-radius: 2px; background: rgba(162,18,23,0.06); }

  /* Canticles table */
  .canticle-table { font-size: 0.82rem; margin: 0 0 0.5rem; }
  .canticle-table th { text-align: left; }
  .canticle-name { font-family: var(--font-ui, sans-serif); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.02em; white-space: nowrap; }
  .legacy-name { font-size: 0.78rem; opacity: 0.75; white-space: nowrap; }

  /* Nav */
  .hub-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; animation: fade-up 0.8s 0.9s both; }
  .nav-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-ui, sans-serif); text-transform: uppercase; letter-spacing: 0.04em;
    font-size: 0.75rem; padding: 0.55rem 1.2rem;
    border: 1px solid var(--c40k-red, #a21217); color: var(--c40k-red, #a21217);
    text-decoration: none; border-radius: 3px; transition: background 0.15s, color 0.15s;
  }
  .nav-btn:hover { background: var(--c40k-red, #a21217); color: #fff; }
  .nav-btn.primary { background: var(--c40k-red, #a21217); color: #fff; }
  .nav-btn.primary:hover { background: #8a0e12; }
</style>

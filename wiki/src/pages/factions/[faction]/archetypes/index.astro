---
import Layout from '../../../../components/Layout.astro';
import { ALL_FACTIONS } from '../../../../lib/factions';
import { getFactionExtras } from '../../../../lib/factionExtras';
import { findClanIcon } from '../../../../lib/clans';

export async function getStaticPaths() {
  return ALL_FACTIONS.map(f => ({ params: { faction: f.key } }));
}

const { faction: factionKey } = Astro.params;
const config = ALL_FACTIONS.find(f => f.key === factionKey)!;
const { archetypes, legacies, traits } = await getFactionExtras(factionKey!);

function ptsRow(t: { pts_unit: string | null; pts_char: string | null; pts_monster: string | null; pts_veh: string | null }): string {
  return `Unit: ${t.pts_unit ?? '-'} · Char: ${t.pts_char ?? '-'} · Monster: ${t.pts_monster ?? '-'} · Veh: ${t.pts_veh ?? '-'}`;
}
---
<Layout title={`Archetypes — ${config.label} — Custom40k Wiki`}>
  <p class="crumbs">
    <a href="/">&larr; All factions</a> / <a href={`/factions/${factionKey}`}>{config.label}</a> / Archetypes
  </p>

  {archetypes.length > 0 && (
    <>
      <h1>Archetypes</h1>
      <ul class="entry-list">
        {archetypes.map(a => (
          <li>
            <strong>{a.name}</strong>
            <p>{a.desc}</p>
          </li>
        ))}
      </ul>
    </>
  )}

  {legacies.length > 0 && (
    <>
      <h1>Legacies</h1>
      <ul class="entry-list">
        {legacies.map(l => {
          const clan = findClanIcon(l.desc);
          return (
            <li>
              {clan && <img src={clan.icon} alt={clan.name} title={clan.name} width="22" height="22" />}
              <strong>{l.name}</strong>
              <p>{l.desc}</p>
            </li>
          );
        })}
      </ul>
    </>
  )}

  {traits.length > 0 && (
    <>
      <h1>Traits</h1>
      <ul class="entry-list">
        {traits.map(t => (
          <li>
            <strong>{t.name}</strong>
            <p>{t.desc}</p>
            <p class="pts">{ptsRow(t)}</p>
          </li>
        ))}
      </ul>
    </>
  )}
</Layout>

<style>
  .entry-list { padding-left: 1.1rem; font-size: 0.85rem; }
  .entry-list li { margin-bottom: 0.7rem; }
  .entry-list img { vertical-align: middle; margin-right: 0.25rem; }
  .entry-list p { margin: 0.15rem 0 0; font-family: var(--font-ui, system-ui, sans-serif); font-size: 0.8rem; white-space: pre-line; }
  .pts { opacity: 0.75; font-size: 0.72rem; }
</style>

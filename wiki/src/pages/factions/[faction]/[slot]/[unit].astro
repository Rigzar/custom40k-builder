---
import Layout from '../../../../components/Layout.astro';
import StatTable from '../../../../components/StatTable.astro';
import WeaponTable from '../../../../components/WeaponTable.astro';
import AbilityList from '../../../../components/AbilityList.astro';
import { ALL_FACTIONS } from '../../../../lib/factions';
import { getFactionUnits } from '../../../../lib/units';
import { slugify } from '../../../../lib/slugs';
import { getSlotIcon } from '../../../../lib/slots';

export async function getStaticPaths() {
  const paths = [];
  for (const f of ALL_FACTIONS) {
    const { units, slot_to_units } = await getFactionUnits(f.key);
    for (const [slot, names] of Object.entries(slot_to_units)) {
      for (const name of names) {
        const unit = units[name];
        if (!unit) {
          console.warn(`[wiki] ${f.key}: slot_to_units["${slot}"] references unknown unit "${name}" — skipping`);
          continue;
        }
        paths.push({
          params: { faction: f.key, slot: slugify(slot), unit: slugify(name) },
          props: { unit, slot, factionLabel: f.label },
        });
      }
    }
  }
  return paths;
}

const { faction: factionKey } = Astro.params;
const { unit, slot, factionLabel } = Astro.props;
const config = ALL_FACTIONS.find(f => f.key === factionKey)!;
const slotIcon = getSlotIcon(slot);

const minModels = Math.min(...unit.models.map(m => m.min).filter(n => n > 0));
const maxModels = Math.max(...unit.models.map(m => m.max).filter(n => n > 0));
const costLabel = unit.models.length === 1
  ? `${unit.min_cost} pts`
  : `${unit.min_cost}+ pts`;
---
<Layout title={`${unit.name} — ${factionLabel} — Custom40k Wiki`}>
  <p class="crumbs">
    <a href="/factions">&larr; All factions</a> /
    <a href={`/factions/${factionKey}`}>{factionLabel}</a> /
    <a href={`/factions/${factionKey}/units`}>Units</a> /
    {slotIcon
      ? <span class="crumb-slot"><img src={slotIcon} alt="" width="13" height="13" /> {slot}</span>
      : slot}
  </p>

  <!-- Unit header -->
  <div class="unit-header">
    <div class="unit-header-row">
      <img src={`/faction-symbols/${config.symbol}`} alt="" class="unit-faction-sym" width="36" height="36" />
      {slotIcon && (
        <span class="unit-slot-pill">
          <img src={slotIcon} alt="" width="14" height="14" />
          {slot}
        </span>
      )}
    </div>
    <h1 class="unit-name">{unit.name}</h1>
    <p class="unit-type-line">{unit.unit_type}</p>
    <div class="unit-meta-row">
      <span class="meta-cost">{costLabel}</span>
      {(minModels > 0 && maxModels > 0) && (
        <span class="meta-size">
          {minModels === maxModels ? `${minModels}` : `${minModels}–${maxModels}`} model{maxModels !== 1 ? 's' : ''}
        </span>
      )}
    </div>
    <div class="unit-badges">
      {unit.is_character && <span class="u-badge badge-char">Character</span>}
      {unit.is_psyker && <span class="u-badge badge-psy">Psyker</span>}
      {unit.is_vehicle && <span class="u-badge badge-veh">Vehicle</span>}
      {unit.is_monster && <span class="u-badge badge-mon">Monster</span>}
      {unit.has_armory_access && <span class="u-badge badge-arm">Armory access</span>}
      {unit.champion_has_armory && <span class="u-badge badge-arm">Champion armory</span>}
      {unit.has_veteran_abilities && <span class="u-badge badge-vet">Veteran abilities</span>}
      {unit.advisor && <span class="u-badge badge-adv">Advisor</span>}
    </div>
  </div>

  <!-- Stats -->
  <section class="reveal">
    <StatTable models={unit.models} />
    {unit.variant_models.length > 0 && <StatTable models={unit.variant_models} title="Variants" />}
  </section>

  <!-- Equipped with -->
  {unit.equipped_with && (
    <p class="equipped-with reveal">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true" style="opacity:0.6;vertical-align:middle;margin-right:0.3rem"><path d="M2 10 L6 2 L10 10 L7.5 8.5 L6 11 L4.5 8.5 Z"/></svg>
      {unit.equipped_with}
    </p>
  )}

  <!-- Weapons -->
  {unit.weapons.length > 0 && (
    <section class="reveal">
      <h2>Weapons</h2>
      <WeaponTable weapons={unit.weapons} />
    </section>
  )}

  <!-- Wargear options -->
  {unit.option_groups.length > 0 && (
    <section class="reveal">
      <h2>Wargear Options</h2>
      <div class="option-groups">
        {unit.option_groups.map(g => (
          <div class="option-group">
            <p class="option-header">
              {g.header}
              {g.inline_pts != null && g.inline_pts > 0 && (
                <span class="option-pts">+{g.inline_pts} pts</span>
              )}
            </p>
            {g.choices.length > 0 && (
              <ul class="option-choices">
                {g.choices.map((c: { name: string; points: number }) => (
                  <li>
                    <span class="choice-name">{c.name}</span>
                    {c.points > 0 && <span class="choice-pts">+{c.points} pts</span>}
                    {c.points === 0 && <span class="choice-pts free">free</span>}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Abilities -->
  {unit.abilities.length > 0 && (
    <section class="reveal">
      <h2>Abilities</h2>
      <AbilityList abilities={unit.abilities} />
    </section>
  )}
</Layout>

<style>
  /* ── Header ─────────────────────────────────── */
  .unit-header {
    margin-bottom: 1.4rem;
    padding-bottom: 0.8rem;
    border-bottom: 2px solid var(--c40k-red, #a21217);
  }
  .unit-header-row {
    display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem;
  }
  .unit-faction-sym { object-fit: contain; opacity: 0.85; }
  .unit-slot-pill {
    display: inline-flex; align-items: center; gap: 0.25rem;
    font-family: var(--font-ui, sans-serif); font-size: 0.68rem;
    text-transform: uppercase; letter-spacing: 0.05em;
    padding: 0.2rem 0.55rem; border: 1px solid var(--c40k-steel, #394950);
    border-radius: 2px; color: var(--c40k-steel, #394950);
    background: rgba(57,73,80,0.06);
  }
  .unit-slot-pill img { object-fit: contain; opacity: 0.8; filter: invert(0.2); }

  .unit-name { margin: 0.1rem 0 0.2rem; border-bottom: none; padding-bottom: 0; }
  .unit-type-line { opacity: 0.65; font-style: italic; font-size: 0.82rem; margin: 0 0 0.4rem; }

  .unit-meta-row {
    display: flex; align-items: center; gap: 1rem; margin-bottom: 0.55rem;
    font-family: var(--font-ui, sans-serif); font-size: 0.75rem;
  }
  .meta-cost {
    font-weight: bold; color: var(--c40k-red, #a21217);
    font-size: 0.88rem;
  }
  .meta-size { opacity: 0.7; }

  .unit-badges { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .u-badge {
    font-family: var(--font-ui, sans-serif); font-size: 0.65rem;
    text-transform: uppercase; letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem; border-radius: 2px; border: 1px solid;
  }
  .badge-char { background: rgba(162,18,23,0.1);  border-color: var(--c40k-red, #a21217);  color: var(--c40k-red, #a21217); }
  .badge-psy  { background: rgba(80,30,120,0.1);  border-color: #7020a0; color: #7020a0; }
  .badge-veh  { background: rgba(57,73,80,0.1);   border-color: var(--c40k-steel, #394950); color: var(--c40k-steel, #394950); }
  .badge-mon  { background: rgba(120,60,20,0.1);  border-color: #784020; color: #784020; }
  .badge-arm  { background: rgba(20,100,50,0.1);  border-color: #145032; color: #145032; }
  .badge-vet  { background: rgba(140,100,20,0.1); border-color: #8c6414; color: #8c6414; }
  .badge-adv  { background: rgba(20,60,120,0.1);  border-color: #143c78; color: #143c78; }

  /* ── Equipped with ──────────────────────────── */
  .equipped-with {
    font-size: 0.82rem; opacity: 0.8; margin: 0.5rem 0 0.8rem;
    padding: 0.4rem 0.7rem;
    border-left: 2px solid rgba(162,18,23,0.4);
    background: rgba(255,255,255,0.25);
  }

  /* ── Crumb slot ─────────────────────────────── */
  .crumb-slot { display: inline-flex; align-items: center; gap: 0.2rem; }
  .crumb-slot img { object-fit: contain; vertical-align: middle; opacity: 0.7; filter: invert(0.3); }

  /* ── Option groups ──────────────────────────── */
  .option-groups { display: flex; flex-direction: column; gap: 0.8rem; }
  .option-group {
    padding: 0.6rem 0.8rem;
    background: rgba(255,255,255,0.3);
    border: 1px solid rgba(57,73,80,0.2);
    border-radius: 3px;
  }
  .option-header {
    margin: 0 0 0.3rem; font-size: 0.84rem;
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.4rem;
  }
  .option-pts {
    font-family: var(--font-ui, sans-serif); font-size: 0.7rem;
    color: var(--c40k-red, #a21217); font-weight: bold;
    white-space: nowrap;
  }
  .option-choices {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .option-choices li {
    display: flex; align-items: baseline; gap: 0.5rem;
    font-size: 0.82rem; padding: 0.15rem 0.5rem;
    border-radius: 2px; background: rgba(255,255,255,0.2);
  }
  .choice-name { flex: 1; }
  .choice-pts {
    font-family: var(--font-ui, sans-serif); font-size: 0.68rem;
    font-weight: bold; color: var(--c40k-red, #a21217);
    white-space: nowrap;
  }
  .choice-pts.free { color: #145032; }
</style>

---
import Layout from '../../../../components/Layout.astro';
import { ALL_FACTIONS } from '../../../../lib/factions';
import { getFactionExtras } from '../../../../lib/factionExtras';

export async function getStaticPaths() {
  return ALL_FACTIONS.map(f => ({ params: { faction: f.key } }));
}

const { faction: factionKey } = Astro.params;
const config = ALL_FACTIONS.find(f => f.key === factionKey)!;
const { disciplines } = await getFactionExtras(factionKey!);
const disciplineNames = Object.keys(disciplines);

function slug(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
---
<Layout title={`Psychic powers — ${config.label} — Custom40k Wiki`}>
  <p class="crumbs">
    <a href="/factions">&larr; All factions</a> / <a href={`/factions/${factionKey}`}>{config.label}</a> / Psychic powers
  </p>
  <h1>Psychic powers</h1>

  {disciplineNames.length > 1 && (
    <nav class="toc">
      <strong>Contents</strong>
      <ul>
        {disciplineNames.map(name => (
          <li><a href={`#${slug(name)}`}>{name}</a></li>
        ))}
      </ul>
    </nav>
  )}

  {disciplineNames.map(name => (
    <section>
      <h2 id={slug(name)}>{name}</h2>
      <table class="power-table">
        <thead>
          <tr>
            <th>Power</th>
            <th>Type</th>
            <th>Range</th>
            <th>Target</th>
            <th>Cast value</th>
            <th>Effect</th>
            <th>Duration</th>
            <th>Complexity</th>
          </tr>
        </thead>
        <tbody>
          {disciplines[name].map(p => (
            <tr>
              <td>{p.name}</td>
              <td>{p.type ?? '-'}</td>
              <td>{p.range ?? '-'}</td>
              <td>{p.target ?? '-'}</td>
              <td>{p.cast_value ?? '-'}</td>
              <td>{p.effect ?? '-'}</td>
              <td>{p.duration ?? '-'}</td>
              <td>{p.complexity ?? '-'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}
</Layout>

<style>
  .power-table th:not(:first-child):not(:nth-child(6)),
  .power-table td:not(:first-child):not(:nth-child(6)) { text-align: center; }
  .toc {
    background: rgba(255,255,255,0.35); border: 1px solid #9a978b; border-radius: 4px;
    padding: 0.7rem 1rem; margin: 0.8rem 0 1.2rem; font-size: 0.82rem;
  }
  .toc strong { font-family: var(--font-ui, sans-serif); text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.72rem; }
  .toc ul { columns: 2; column-gap: 1.5rem; margin: 0.4rem 0 0; padding-left: 1.1rem; }
</style>

---
import Layout from '../../../../components/Layout.astro';
import ArmoryWeaponTable from '../../../../components/ArmoryWeaponTable.astro';
import ArmoryEquipmentList from '../../../../components/ArmoryEquipmentList.astro';
import { ALL_FACTIONS } from '../../../../lib/factions';
import { getFactionExtras } from '../../../../lib/factionExtras';
import { getArmoryKeyIcon } from '../../../../lib/legacyIcons';
import { wt } from '../../../../lib/i18n';

export async function getStaticPaths() {
  return ALL_FACTIONS.map(f => ({ params: { faction: f.key } }));
}

const { faction: factionKey } = Astro.params;
const config = ALL_FACTIONS.find(f => f.key === factionKey)!;
const { armoryGeneral, armoryFaction } = await getFactionExtras(factionKey!);

const factionEntries = Object.entries(armoryFaction);

function tabId(s: string): string {
  return 'tab-' + s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const hasGeneral = armoryGeneral.weapons.length > 0 || armoryGeneral.equipment.length > 0
  || (armoryGeneral.daemon_weapons && armoryGeneral.daemon_weapons.length > 0);

const allTabs = [
  ...(hasGeneral ? [{ id: tabId('general'), label: armoryGeneral.name, icon: null as string | null }] : []),
  ...factionEntries.map(([label]) => ({
    id: tabId(label),
    label,
    icon: getArmoryKeyIcon(factionKey!, label),
  })),
];
const singleTab = allTabs.length <= 1;
---
<Layout title={`Armory — ${config.label} — Custom40k Wiki`}>
  <p class="crumbs">
    <a href="/factions">&larr; {wt('crumbAllFactions')}</a> /
    <a href={`/factions/${factionKey}`}>{config.label}</a> / {wt('headingArmory')}
  </p>
  <h1>{wt('headingArmory')}</h1>

  {!singleTab && (
    <div class="tab-bar" role="tablist">
      {allTabs.map((tab, i) => (
        <button
          class={`tab-btn${i === 0 ? ' active' : ''}`}
          data-tab={tab.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {tab.icon && <img src={tab.icon} alt="" width="18" height="18" class="tab-icon" />}
          {tab.label}
        </button>
      ))}
    </div>
  )}

  {/* General armory panel — first tab, always starts active */}
  {hasGeneral && (
    <div id={tabId('general')} class="tab-panel active">
      {armoryGeneral.weapons.length > 0 && (
        <>
          <h2>{wt('headingWeapons')}</h2>
          <ArmoryWeaponTable items={armoryGeneral.weapons} />
        </>
      )}
      {armoryGeneral.equipment.length > 0 && (
        <>
          <h2>{wt('headingEquipment')}</h2>
          <ArmoryEquipmentList items={armoryGeneral.equipment} />
        </>
      )}
      {armoryGeneral.daemon_weapons && armoryGeneral.daemon_weapons.length > 0 && (
        <>
          <h2>{wt('headingDaemonWeapons')}</h2>
          <ArmoryWeaponTable items={armoryGeneral.daemon_weapons} />
        </>
      )}
    </div>
  )}

  {/* Faction armory panels — first is active only when there's no general armory */}
  {factionEntries.map(([label, armory], idx) => {
    const icon = getArmoryKeyIcon(factionKey!, label);
    const isFirst = !hasGeneral && idx === 0;
    return (
      <div id={tabId(label)} class={`tab-panel${isFirst ? ' active' : ''}`}>
        {icon && !singleTab && (
          <div class="section-badge">
            <img src={icon} alt={label} width="36" height="36" class="section-icon" />
            <span>{armory.name}</span>
          </div>
        )}
        {singleTab && (
          <h2>
            {icon && <img src={icon} alt={label} width="22" height="22" class="inline-icon" />}
            {armory.name}
          </h2>
        )}
        {armory.weapons.length > 0 && (
          <>
            {!singleTab && <h2>{wt('headingWeapons')}</h2>}
            {singleTab && <h3>{wt('headingWeapons')}</h3>}
            <ArmoryWeaponTable items={armory.weapons} />
          </>
        )}
        {armory.equipment.length > 0 && (
          <>
            {!singleTab && <h2>{wt('headingEquipment')}</h2>}
            {singleTab && <h3>{wt('headingEquipment')}</h3>}
            <ArmoryEquipmentList items={armory.equipment} />
          </>
        )}
      </div>
    );
  })}
</Layout>

<style>
  .tab-bar {
    display: flex; flex-wrap: wrap; gap: 0.3rem;
    margin-bottom: 1.2rem;
    border-bottom: 2px solid var(--c40k-red, #a21217);
    padding-bottom: 0;
  }
  .tab-btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-family: var(--font-ui, sans-serif); text-transform: uppercase;
    letter-spacing: 0.04em; font-size: 0.72rem;
    padding: 0.45rem 1rem; cursor: pointer;
    border: 1px solid transparent; border-bottom: none;
    border-radius: 3px 3px 0 0;
    background: rgba(255,255,255,0.2);
    color: var(--c40k-ink, #2a2420);
    transition: background 0.12s, color 0.12s;
    position: relative; bottom: -2px;
  }
  .tab-btn:hover { background: rgba(162,18,23,0.1); color: var(--c40k-red, #a21217); }
  .tab-btn.active {
    background: var(--c40k-red, #a21217); color: #fff;
    border-color: var(--c40k-red, #a21217);
  }
  .tab-btn.active .tab-icon { filter: brightness(0) invert(1); }
  .tab-icon { object-fit: contain; }

  .tab-panel { display: none; }
  .tab-panel.active {
    display: block;
    animation: tab-fade 0.22s ease both;
  }

  .section-badge {
    display: flex; align-items: center; gap: 0.7rem;
    margin-bottom: 1rem; padding: 0.6rem 0;
    border-bottom: 1px solid rgba(162,18,23,0.3);
  }
  .section-badge span {
    font-family: var(--font-heading, sans-serif); font-size: 1.2rem;
    text-transform: uppercase; letter-spacing: 0.04em; color: var(--c40k-red, #a21217);
  }
  .section-icon { object-fit: contain; }
  .inline-icon { vertical-align: middle; margin-right: 0.35rem; object-fit: contain; }
</style>

<script is:inline>
  (function () {
    const buttons = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');
    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        buttons.forEach(function (b) {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        panels.forEach(function (p) { p.classList.remove('active'); });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        var target = document.getElementById(btn.dataset.tab);
        if (target) target.classList.add('active');
      });
    });
  })();
</script>
